{
  "$schema": "https://github.com/FrancescoStabile/numasec/blob/main/theme.schema.json",
  "defs": {
    "void": "#050505",
    "abyss": "#0a0a0a",
    "deep": "#111111",
    "shade": "#171717",
    "dim": "#1f1f1f",
    "mist": "#2a2a2a",
    "ash": "#3a3a3a",
    "slate": "#555555",
    "neon": "#f50057",
    "glow": "#ff4081",
    "ember": "#c51162",
    "cyan": "#00e5ff",
    "frost": "#d0d0d0",
    "ice": "#8a8a8a",
    "yellow": "#f5a623",
    "crimson": "#ff1744",
    "ghost": "#8a8a9a",
    "bone": "#e0e0e0",
    "white": "#f5f5f5",
    "lightBg": "#f2f2f2",
    "lightPanel": "#e6e6e6",
    "lightElem": "#dadada",
    "lightBorder": "#b0b0b0",
    "lightText": "#1a1a1a",
    "lightMuted": "#666666",
    "lightGreen": "#0a8f3c",
    "lightCyan": "#0d8a72",
    "lightIce": "#444444",
    "lightYellow": "#a56a10",
    "lightRed": "#c41530"
  },
  "theme": {
    "primary": { "dark": "neon", "light": "lightRed" },
    "secondary": { "dark": "frost", "light": "lightMuted" },
    "accent": { "dark": "ice", "light": "lightIce" },
    "error": { "dark": "crimson", "light": "lightRed" },
    "warning": { "dark": "yellow", "light": "lightYellow" },
    "success": { "dark": "glow", "light": "lightRed" },
    "info": { "dark": "frost", "light": "lightMuted" },
    "text": { "dark": "white", "light": "lightText" },
    "textMuted": { "dark": "ghost", "light": "lightMuted" },
    "background": { "dark": "void", "light": "lightBg" },
    "backgroundPanel": { "dark": "void", "light": "lightBg" },
    "backgroundElement": { "dark": "void", "light": "lightBg" },
    "border": { "dark": "ash", "light": "lightBorder" },
    "borderActive": { "dark": "neon", "light": "lightRed" },
    "borderSubtle": { "dark": "dim", "light": "lightElem" },
    "diffAdded": { "dark": "glow", "light": "lightGreen" },
    "diffRemoved": { "dark": "crimson", "light": "lightRed" },
    "diffContext": { "dark": "ghost", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "frost", "light": "lightMuted" },
    "diffHighlightAdded": { "dark": "glow", "light": "#16a34a" },
    "diffHighlightRemoved": { "dark": "#f87171", "light": "#ef4444" },
    "diffAddedBg": { "dark": "#0a1a0a", "light": "#dcfce7" },
    "diffRemovedBg": { "dark": "#1f0a0e", "light": "#fee2e2" },
    "diffContextBg": { "dark": "abyss", "light": "lightPanel" },
    "diffLineNumber": { "dark": "slate", "light": "lightMuted" },
    "diffAddedLineNumberBg": { "dark": "#081a08", "light": "#d1fae5" },
    "diffRemovedLineNumberBg": { "dark": "#1a080c", "light": "#fecaca" },
    "markdownText": { "dark": "bone", "light": "lightText" },
    "markdownHeading": { "dark": "neon", "light": "lightRed" },
    "markdownLink": { "dark": "frost", "light": "lightMuted" },
    "markdownLinkText": { "dark": "frost", "light": "lightMuted" },
    "markdownCode": { "dark": "glow", "light": "lightRed" },
    "markdownBlockQuote": { "dark": "ghost", "light": "lightMuted" },
    "markdownEmph": { "dark": "yellow", "light": "lightYellow" },
    "markdownStrong": { "dark": "neon", "light": "lightRed" },
    "markdownHorizontalRule": { "dark": "ash", "light": "lightBorder" },
    "markdownListItem": { "dark": "neon", "light": "lightRed" },
    "markdownListEnumeration": { "dark": "frost", "light": "lightMuted" },
    "markdownImage": { "dark": "frost", "light": "lightMuted" },
    "markdownImageText": { "dark": "frost", "light": "lightMuted" },
    "markdownCodeBlock": { "dark": "white", "light": "lightText" },
    "syntaxComment": { "dark": "ghost", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "neon", "light": "lightRed" },
    "syntaxFunction": { "dark": "frost", "light": "lightMuted" },
    "syntaxVariable": { "dark": "glow", "light": "lightRed" },
    "syntaxString": { "dark": "ember", "light": "lightRed" },
    "syntaxNumber": { "dark": "yellow", "light": "lightYellow" },
    "syntaxType": { "dark": "ice", "light": "lightIce" },
    "syntaxOperator": { "dark": "neon", "light": "lightRed" },
    "syntaxPunctuation": { "dark": "bone", "light": "lightText" }
  }
}
