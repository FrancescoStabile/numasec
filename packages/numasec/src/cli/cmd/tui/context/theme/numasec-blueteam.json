{
  "$schema": "https://github.com/FrancescoStabile/numasec/blob/main/theme.schema.json",
  "defs": {
    "void": "#050a12",
    "abyss": "#080f1a",
    "deep": "#0c1626",
    "shade": "#121f33",
    "dim": "#172941",
    "mist": "#1f3555",
    "ash": "#2a466b",
    "slate": "#406590",
    "neon": "#3b82f6",
    "glow": "#60a5fa",
    "ember": "#2563eb",
    "cyan": "#06b6d4",
    "frost": "#7dd3fc",
    "ice": "#38bdf8",
    "yellow": "#fbbf24",
    "crimson": "#ef4444",
    "ghost": "#64748b",
    "bone": "#cbd5e1",
    "white": "#e2e8f0",
    "lightBg": "#f1f5f9",
    "lightPanel": "#e2e8f0",
    "lightElem": "#cbd5e1",
    "lightBorder": "#94a3b8",
    "lightText": "#0f172a",
    "lightMuted": "#64748b",
    "lightGreen": "#059669",
    "lightCyan": "#0891b2",
    "lightIce": "#0284c7",
    "lightYellow": "#b45309",
    "lightRed": "#dc2626"
  },
  "theme": {
    "primary": { "dark": "neon", "light": "lightIce" },
    "secondary": { "dark": "cyan", "light": "lightCyan" },
    "accent": { "dark": "ice", "light": "lightIce" },
    "error": { "dark": "crimson", "light": "lightRed" },
    "warning": { "dark": "yellow", "light": "lightYellow" },
    "success": { "dark": "glow", "light": "lightIce" },
    "info": { "dark": "frost", "light": "lightCyan" },
    "text": { "dark": "white", "light": "lightText" },
    "textMuted": { "dark": "ghost", "light": "lightMuted" },
    "background": { "dark": "void", "light": "lightBg" },
    "backgroundPanel": { "dark": "void", "light": "lightBg" },
    "backgroundElement": { "dark": "void", "light": "lightBg" },
    "border": { "dark": "ash", "light": "lightBorder" },
    "borderActive": { "dark": "neon", "light": "lightIce" },
    "borderSubtle": { "dark": "dim", "light": "lightElem" },
    "diffAdded": { "dark": "ember", "light": "lightGreen" },
    "diffRemoved": { "dark": "crimson", "light": "lightRed" },
    "diffContext": { "dark": "ghost", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "cyan", "light": "lightCyan" },
    "diffHighlightAdded": { "dark": "glow", "light": "#16a34a" },
    "diffHighlightRemoved": { "dark": "#f87171", "light": "#ef4444" },
    "diffAddedBg": { "dark": "#0a1a2a", "light": "#dcfce7" },
    "diffRemovedBg": { "dark": "#1f0a0a", "light": "#fee2e2" },
    "diffContextBg": { "dark": "abyss", "light": "lightPanel" },
    "diffLineNumber": { "dark": "slate", "light": "lightMuted" },
    "diffAddedLineNumberBg": { "dark": "#08142a", "light": "#d1fae5" },
    "diffRemovedLineNumberBg": { "dark": "#1a0808", "light": "#fecaca" },
    "markdownText": { "dark": "bone", "light": "lightText" },
    "markdownHeading": { "dark": "neon", "light": "lightIce" },
    "markdownLink": { "dark": "cyan", "light": "lightCyan" },
    "markdownLinkText": { "dark": "frost", "light": "lightCyan" },
    "markdownCode": { "dark": "ember", "light": "lightIce" },
    "markdownBlockQuote": { "dark": "ghost", "light": "lightMuted" },
    "markdownEmph": { "dark": "yellow", "light": "lightYellow" },
    "markdownStrong": { "dark": "neon", "light": "lightIce" },
    "markdownHorizontalRule": { "dark": "ash", "light": "lightBorder" },
    "markdownListItem": { "dark": "neon", "light": "lightIce" },
    "markdownListEnumeration": { "dark": "cyan", "light": "lightCyan" },
    "markdownImage": { "dark": "frost", "light": "lightCyan" },
    "markdownImageText": { "dark": "cyan", "light": "lightCyan" },
    "markdownCodeBlock": { "dark": "white", "light": "lightText" },
    "syntaxComment": { "dark": "ghost", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "cyan", "light": "lightCyan" },
    "syntaxFunction": { "dark": "frost", "light": "lightCyan" },
    "syntaxVariable": { "dark": "glow", "light": "lightIce" },
    "syntaxString": { "dark": "ember", "light": "lightIce" },
    "syntaxNumber": { "dark": "yellow", "light": "lightYellow" },
    "syntaxType": { "dark": "ice", "light": "lightIce" },
    "syntaxOperator": { "dark": "neon", "light": "lightIce" },
    "syntaxPunctuation": { "dark": "bone", "light": "lightText" }
  }
}
